 #include <stdio.h>

int main()
{
    int m, n;
    scanf("%d %d", &m, &n);
    int max_val = (m > n) ? m : n;
    char goc = 'a' + max_val - 1;
    for (int i = 1; i <= m; i++)
    {
        int da_in = 0;
        char chu_in = goc;
        int so_luong_giam = i - 1;
        for (int j = 0; j < so_luong_giam; j++)
        {
            if (da_in < n)
            {
                printf("%c", chu_in);
                chu_in--;
                da_in++;
            }
        }
        while (da_in < n)
        {
            printf("%c", chu_in);
            da_in++;
        }
        printf("\n");
    }
    return 0;
}

